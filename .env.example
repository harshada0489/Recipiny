# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# For production builds (EAS), set these as project-scoped secrets instead:
#   npx eas secret:create --scope project --name EXPO_PUBLIC_RECIPINY_API_KEY      --value <secret> --type string
#   npx eas secret:create --scope project --name EXPO_PUBLIC_RECIPINY_API_ENDPOINT --value <url>    --type string

# Your deployed Cloudflare Worker URL (must end with /import)
EXPO_PUBLIC_RECIPINY_API_ENDPOINT=https://recipiny-importer.<your-subdomain>.workers.dev/import

# Shared secret — must match the Worker's RECIPINY_API_KEY env var
EXPO_PUBLIC_RECIPINY_API_KEY=your-long-random-shared-secret
